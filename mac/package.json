{
  "name": "todoline",
  "version": "1.0.0",
  "description": "A chronological daily to-do timeline",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder --mac"
  },
  "build": {
    "appId": "com.susantang.todoline",
    "productName": "Todoline",
    "files": [
      "main.js",
      "todoline.html"
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "target": "dmg"
    },
    "win": {
      "target": "nsis"
    }
  },
  "devDependencies": {
    "electron": "^30.0.0",
    "electron-builder": "^24.0.0"
  }
}
