{
  "name": "todoline",
  "version": "1.0.0",
  "description": "A chronological daily to-do timeline",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder --mac"
  },
  "build": {
    "appId": "com.susantang.todoline",
    "productName": "Todoline",
    "files": [
      "main.js",
      "app.html",
      "add-task.html",
      "preload.js",
      "preload-add.js"
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "target": "dmg"
    },
    "win": {
      "target": "nsis"
    }
  },
  "devDependencies": {
    "electron": "^30.0.0",
    "electron-builder": "^24.13.3"
  }
}
